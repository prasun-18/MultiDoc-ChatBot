# Hugging Face API token (https://huggingface.co/settings/tokens)
HUGGINGFACEHUB_API_TOKEN=

# LLM settings (Hugging Face Inference API)
HF_MODEL_ID=meta-llama/Llama-3.2-1B-Instruct
HF_TEMPERATURE=0.2
HF_MAX_NEW_TOKENS=512

# Embeddings model for document search
EMBEDDING_MODEL_NAME=sentence-transformers/all-mpnet-base-v2

# Text chunking when uploading documents
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Typing animation delay (seconds per character)
TYPING_DELAY_DOC=0.02
TYPING_DELAY_CHAT=0.02
